# OpenClawSquad Environment Variables

# ===========================================
# LLM Providers (pelo menos um e obrigatorio)
# ===========================================

# Minimax (Recomendado - M2.7)
# Obtain at: https://platform.minimax.io/
MINIMAX_API_KEY=

# OpenAI
# Obtain at: https://platform.openai.com/
OPENAI_API_KEY=

# Anthropic (Claude)
# Obtain at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ===========================================
# Configuracao do OpenClawSquad (opcional)
# ===========================================

# Provider padrao (auto-detecta se nao definido)
# Opcoes: minimax, openai, anthropic
# OPENCLAWSQUAD_PROVIDER=minimax

# Modelo especifico (usa padrao do provider se nao definido)
# OPENCLAWSQUAD_MODEL=M2.7

# Temperatura (0.0 a 1.0, padrao: 0.7)
# OPENCLAWSQUAD_TEMPERATURE=0.7

# Max tokens por resposta (padrao: 4096)
# OPENCLAWSQUAD_MAX_TOKENS=4096

# ===========================================
# Skills - Integracoes externas
# ===========================================

# Instagram Publisher
# Obtain at: https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Image Hosting (para Instagram Publisher)
# Obtain at: https://api.imgbb.com/
IMGBB_API_KEY=

# Apify (web scraping)
# Obtain at: https://apify.com/
APIFY_TOKEN=
