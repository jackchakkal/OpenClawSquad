# OpenClawSquad Environment Variables

# ===========================================
# LLM Providers (at least one is required)
# ===========================================

# Anthropic (Claude) - Recommended
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI
# Get your key at: https://platform.openai.com/
OPENAI_API_KEY=

# Minimax (M2.7)
# Get your key at: https://platform.minimax.io/
MINIMAX_API_KEY=

# ===========================================
# OpenClawSquad Configuration (optional)
# ===========================================

# Default provider (auto-detects if not set)
# Options: anthropic, openai, minimax
# OPENCLAWSQUAD_PROVIDER=anthropic

# Specific model (uses provider default if not set)
# OPENCLAWSQUAD_MODEL=claude-sonnet-4-20250514

# Temperature (0.0 to 1.0, default: 0.7)
# OPENCLAWSQUAD_TEMPERATURE=0.7

# Max tokens per response (default: 4096)
# OPENCLAWSQUAD_MAX_TOKENS=4096

# Output language (default: en)
# OPENCLAWSQUAD_LANGUAGE=en

# ===========================================
# Skills - External Integrations (optional)
# ===========================================

# Instagram Publisher
# Get your token at: https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Image Hosting (for Instagram Publisher)
# Get your key at: https://api.imgbb.com/
IMGBB_API_KEY=

# Apify (web scraping)
# Get your token at: https://apify.com/
APIFY_TOKEN=
